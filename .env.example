# ============================================================
# Cloud9 Production System (CPS) — 環境変数
# 未設定でも内蔵モックデータでアプリは起動します。
# 本番運用時に以下を設定してください。
# ============================================================

# Supabase（既存プロジェクトを使用）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini（AI改善案生成）
GEMINI_API_KEY=

# CPS 設定
CPS_AI_MODEL=gemini-1.5-flash-latest
CPS_BOTTLENECK_CAUTION_RATIO=1.1
CPS_BOTTLENECK_STOP_DAYS=7
